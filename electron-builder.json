{
  "appId": "com.dentalclinic.billing",
  "productName": "Dental Clinic Billing",
  "directories": {
    "output": "build"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "package.json"
  ],
  "mac": {
    "target": [
      "dmg",
      "zip"
    ],
    "category": "public.app-category.healthcare-fitness",
    "icon": "public/icon.icns"
  },
  "win": {
    "target": [
      "nsis",
      "portable"
    ],
    "icon": "public/icon.ico"
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "category": "Office"
  }
}
